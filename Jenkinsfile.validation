library('JenkinsPipelineUtils') _

properties([
    parameters([
        string(name: 'BACKEND_BUILD', defaultValue: ''),
        string(name: 'FRONTEND_BUILD', defaultValue: ''),
        string(name: 'TRIGGERED_BY')
    ])
])

podTemplate(inheritFrom: 'jenkins-agent kaniko', containers: [
    containerTemplates.k8s('k8s')
]) {
    node(POD_LABEL) {
        def backendMeta
        def frontendMeta
        def jobName = "iot-support-validation-${BUILD_NUMBER}"
        def k8sNamespace = kubectl.currentNamespace()

        stage('Clone repo') {
            git branch: 'main',
                credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                url: 'https://github.com/pvginkel/IoTSupportUI.git'
        }

        stage('Resolve image pair') {
            copyArtifacts(
                projectName: 'IoTSupport',
                selector: params.BACKEND_BUILD ? specific(params.BACKEND_BUILD) : lastSuccessful(),
                filter: 'backend-build.json',
                target: 'backend-meta',
                flatten: true
            )

            copyArtifacts(
                projectName: 'IoTSupportUI',
                selector: params.FRONTEND_BUILD ? specific(params.FRONTEND_BUILD) : lastSuccessful(),
                filter: 'frontend-build.json',
                target: 'frontend-meta',
                flatten: true
            )

            backendMeta = readJSON file: 'backend-meta/backend-build.json'
            frontendMeta = readJSON file: 'frontend-meta/frontend-build.json'

            echo "Testing backend=${backendMeta.tag} (${backendMeta.gitRev})"
            echo "Testing frontend=${frontendMeta.tag} (${frontendMeta.gitRev})"
        }

        stage('Clone source repos') {
            dir('backend-src') {
                git branch: 'main',
                    credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                    url: 'https://github.com/pvginkel/IoTSupport.git'
                sh "git checkout ${backendMeta.gitRev}"
            }
            dir('frontend-src') {
                git branch: 'main',
                    credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                    url: 'https://github.com/pvginkel/IoTSupportUI.git'
                sh "git checkout ${frontendMeta.gitRev}"
            }
        }

        stage('Build validation image') {
            container('kaniko') {
                helmCharts.kaniko(
                    "Dockerfile.validation",
                    ".",
                    [
                        "registry:5000/iot-support-validation:${currentBuild.number}"
                    ]
                )
            }
        }

        stage('Run validation') {
            container('k8s') {
                withCredentials([
                    string(credentialsId: 'S3_ENDPOINT_URL', variable: 'S3_ENDPOINT_URL'),
                    string(credentialsId: 'S3_ACCESS_KEY_ID', variable: 'S3_ACCESS_KEY_ID'),
                    string(credentialsId: 'S3_SECRET_ACCESS_KEY', variable: 'S3_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'KEYCLOAK_TEST_BASE_URL', variable: 'KEYCLOAK_BASE_URL'),
                    string(credentialsId: 'KEYCLOAK_TEST_REALM', variable: 'KEYCLOAK_REALM'),
                    string(credentialsId: 'KEYCLOAK_TEST_IOTSUPPORT_ADMIN_CLIENT_ID', variable: 'KEYCLOAK_ADMIN_CLIENT_ID'),
                    string(credentialsId: 'KEYCLOAK_TEST_IOTSUPPORT_ADMIN_CLIENT_SECRET', variable: 'KEYCLOAK_ADMIN_CLIENT_SECRET'),
                    string(credentialsId: 'KEYCLOAK_TEST_OIDC_TOKEN_URL', variable: 'OIDC_TOKEN_URL'),
                    string(credentialsId: 'ELASTICSEARCH_CLUSTER_URL', variable: 'ELASTICSEARCH_URL'),
                    string(credentialsId: 'ELASTICSEARCH_USERNAME', variable: 'ELASTICSEARCH_USERNAME'),
                    string(credentialsId: 'ELASTICSEARCH_PASSWORD', variable: 'ELASTICSEARCH_PASSWORD'),
                ]) {
                    try {
                        kubectl.startJob("""
                            apiVersion: batch/v1
                            kind: Job
                            metadata:
                              name: ${jobName}
                              namespace: ${k8sNamespace}
                              labels:
                                app.kubernetes.io/name: iot-support-validation
                                app.kubernetes.io/managed-by: jenkins
                                jenkins/build-number: "${BUILD_NUMBER}"
                            spec:
                              backoffLimit: 0
                              activeDeadlineSeconds: 3600
                              ttlSecondsAfterFinished: 3600
                              template:
                                spec:
                                  restartPolicy: Never
                                  containers:
                                    - name: validation
                                      image: registry:5000/iot-support-validation:${currentBuild.number}
                                      imagePullPolicy: Always
                                      env:
                                        - name: S3_ENDPOINT_URL
                                          value: "${S3_ENDPOINT_URL}"
                                        - name: S3_ACCESS_KEY_ID
                                          value: "${S3_ACCESS_KEY_ID}"
                                        - name: S3_SECRET_ACCESS_KEY
                                          value: "${S3_SECRET_ACCESS_KEY}"
                                        - name: S3_BUCKET_NAME
                                          value: "iot-support-validation"
                                        - name: KEYCLOAK_BASE_URL
                                          value: "${KEYCLOAK_BASE_URL}"
                                        - name: KEYCLOAK_REALM
                                          value: "${KEYCLOAK_REALM}"
                                        - name: KEYCLOAK_ADMIN_CLIENT_ID
                                          value: "${KEYCLOAK_ADMIN_CLIENT_ID}"
                                        - name: KEYCLOAK_ADMIN_CLIENT_SECRET
                                          value: "${KEYCLOAK_ADMIN_CLIENT_SECRET}"
                                        - name: OIDC_TOKEN_URL
                                          value: "${OIDC_TOKEN_URL}"
                                        - name: ELASTICSEARCH_URL
                                          value: "${ELASTICSEARCH_URL}"
                                        - name: ELASTICSEARCH_USERNAME
                                          value: "${ELASTICSEARCH_USERNAME}"
                                        - name: ELASTICSEARCH_PASSWORD
                                          value: "${ELASTICSEARCH_PASSWORD}"
                        """.stripIndent())

                        kubectl.waitForJob(jobName, k8sNamespace)

                        def podName = kubectl.getJobPodName(jobName, k8sNamespace)
                        kubectl.savePodLogs(podName, 'validation', k8sNamespace, 'validation-raw.log')

                        sh '''
                            set -euo pipefail

                            mkdir -p test-results

                            awk '
                                /^===JUNIT:.*===$/ {
                                    fname = $0
                                    sub(/^===JUNIT:/, "", fname)
                                    sub(/===$/, "", fname)
                                    content = ""
                                    capture = 1
                                    next
                                }
                                /^===JUNIT_END===$/ {
                                    print content | "base64 -d > test-results/" fname
                                    close("base64 -d > test-results/" fname)
                                    capture = 0
                                    next
                                }
                                capture { content = content (content ? "\\n" : "") $0 }
                                !capture { print }
                            ' validation-raw.log > validation-stripped.log

                            # Strip ANSI escape sequences and Unicode emoji/symbols
                            LC_ALL=C sed \
                                -e $'s/\x1b\[[0-9;]*[a-zA-Z]//g' \
                                -e $'s/\x1b([a-zA-Z]//g' \
                                -e 's/[\xc2-\xc3][\x80-\xbf]//g' \
                                -e 's/\xe2[\x80-\xbf][\x80-\xbf]//g' \
                                -e 's/\xef[\x80-\xbf][\x80-\xbf]//g' \
                                -e 's/\xf0[\x80-\xbf][\x80-\xbf][\x80-\xbf]//g' \
                                validation-stripped.log > validation.log
                        '''
                        archiveArtifacts artifacts: 'validation.log', allowEmptyArchive: true
                        junit testResults: 'test-results/*.xml', allowEmptyResults: true

                        def exitCode = kubectl.getContainerExitCode(podName, 'validation', k8sNamespace)
                        def failReason = kubectl.getJobFailReason(jobName, k8sNamespace)

                        currentBuild.description = "job=${jobName}, pod=${podName}, exit=${exitCode ?: 'n/a'}"

                        if (!exitCode) {
                            error("No exit code found for pod ${podName}${failReason ? " (reason: ${failReason})" : ""}")
                        }

                        if (exitCode != '0') {
                            error("Validation failed with exit code ${exitCode}")
                        }
                    } finally {
                        kubectl.deleteJob(jobName, k8sNamespace)
                    }
                }
            }
        }

        stage('Promote build') {
            container('k8s') {
                sh "crane tag --insecure registry:5000/iotsupport-app${backendMeta.tag} latest"
                sh "crane tag --insecure registry:5000/iotsupport-ui${frontendMeta.tag} latest"
            }
        }

        stage('Deploy Helm charts') {
            build job: 'HelmCharts', wait: false
        }
    }
}
